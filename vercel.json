{
  "version": 2,
  "env": {
    "R2_ACCOUNT_ID": "9cbc66c51dbfc216ec865cd84e9e7400",
    "R2_BUCKET_NAME": "dsa-mastery-media",
    "R2_PUBLIC_BASE_URL": "https://pub-97c9c4489ec044f592e65ea00c33995b.r2.dev"
  },
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/cron/push-reminders.js": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/push-reminders",
      "schedule": "0 * * * *"
    }
  ]
}