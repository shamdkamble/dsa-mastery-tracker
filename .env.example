GEMINI_API_KEY=your-gemini-api-key-here
# Model id only — do NOT include "models/" prefix or quotes
GEMINI_MODEL=gemini-2.5-flash
AUTH_SECRET=change-this-to-a-long-random-string
PORT=8080

# MongoDB Atlas (required for user accounts)
# Include database name in the URI, e.g. ...mongodb.net/dsa-mastery?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/dsa-mastery?retryWrites=true&w=majority&appName=Cluster0