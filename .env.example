GEMINI_API_KEY=your-gemini-api-key-here
# Model id only — do NOT include "models/" prefix or quotes
GEMINI_MODEL=gemini-2.5-flash
AUTH_SECRET=change-this-to-a-long-random-string
PORT=8080

# Production (Vercel): add Blob storage in the Vercel dashboard — it injects this automatically.
# Without it, user accounts are wiped on every deploy.
# BLOB_READ_WRITE_TOKEN=