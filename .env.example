GEMINI_API_KEY=your-gemini-api-key-here
# Model id only — do NOT include "models/" prefix or quotes
GEMINI_MODEL=gemini-2.5-flash
AUTH_SECRET=change-this-to-a-long-random-string
PORT=8080

# Production (Vercel) — connect ONE of these in Vercel Dashboard → Storage:
#
# Option A (recommended): Vercel KV / Upstash Redis — auto-injects:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
#
# Option B: Vercel Blob — auto-injects:
# BLOB_READ_WRITE_TOKEN=
#
# Without persistent storage, user accounts are wiped on every deploy.