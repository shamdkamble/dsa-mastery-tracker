GEMINI_API_KEY=your-gemini-api-key-here
# Model id only — do NOT include "models/" prefix or quotes
GEMINI_MODEL=gemini-2.5-flash

# Groq — primary for hooks & small AI tasks; fallback when Gemini is unavailable
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_HOOKS_MODEL=llama-3.3-70b-versatile
AUTH_SECRET=change-this-to-a-long-random-string
PORT=8080

# Web Push (PWA notifications) — run: npm run generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com

# Scheduled push reminders (Vercel Cron — hourly check, sends at 9 AM / 8 PM / Sun 6 PM Asia/Kolkata)
CRON_SECRET=generate-a-long-random-string

# MongoDB Atlas (required) — Option A: separate vars (recommended for Vercel)
MONGODB_USER=your_db_user
MONGODB_PASSWORD=your_db_password
MONGODB_HOST=cluster0.xxxxx.mongodb.net
MONGODB_DB=dsa-mastery

# Option B: full connection string (local dev)
# MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/dsa-mastery?retryWrites=true&w=majority&appName=Cluster0

# Cloudflare R2 — image storage (profile photos, chat images)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=dsa-mastery-media
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
# Optional — defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_S3_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com